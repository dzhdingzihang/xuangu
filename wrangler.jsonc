{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "xuangu",
  "main": "./src/index.js",
  "compatibility_date": "2026-05-29",
  "workers_dev": false,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "routes": [
    {
      "pattern": "xuangu.alixjd.com/*",
      "zone_name": "alixjd.com"
    }
  ]
}
